{
  "metadata": {
    "componentName": "MangaDexAPI",
    "description": "MangaDex runtime tracker package settings",
    "version": "1.0.0"
  },
  "settings": {
    "serviceName": "mangadex",
    "api": {
      "baseUrl": "https://api.mangadex.org",
      "authUrl": "https://auth.mangadex.org/realms/mangadex/protocol/openid-connect",
      "endPoints": {
        "manga": {
          "template": "${baseUrl}/manga"
        },
        "mangaById": {
          "template": "${baseUrl}/manga/${id}"
        }
      }
    },
    "network": {
      "timeoutMs": 15000
    },
    "search": {
      "limit": 10
    }
  }
}
